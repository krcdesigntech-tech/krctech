# ================================
# KRCTech DocAI - 환경 변수 설정
# ================================
# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요.
# .env.local 파일은 절대 git에 커밋하지 마세요.

# ── Supabase ──────────────────────────────────────────
# Supabase 프로젝트 → Settings → API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (서버에서만 사용, 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cloudflare R2 ─────────────────────────────────────
# Cloudflare Dashboard → R2 → Manage R2 API Tokens에서 생성
CF_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=krctech-documents

# ── HuggingFace ───────────────────────────────────────
# https://huggingface.co/settings/tokens 에서 생성 (Write 토큰)
# 서버에서만 사용
HF_TOKEN=hf_your_token_here

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
